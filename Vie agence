    <script>
        // Initialize Lucide Icons
        lucide.createIcons();

        // Optional: Add simple active state to sidebar links based on scroll
        const sections = document.querySelectorAll("section");
        const navLi = document.querySelectorAll("nav ul li a");
        window.onscroll = () => {
        var current = "";
        sections.forEach((section) => {
            const sectionTop = section.offsetTop;
            if (pageYOffset >= sectionTop - 150) {
            current = section.getAttribute("id"); }
        });

        navLi.forEach((a) => {
            a.classList.remove("bg-white/10", "text-white");
            a.classList.add("text-slate-300");
            if (a.getAttribute("href").includes(current) && current !== "") {
                a.classList.add("bg-white/10", "text-white");
                a.classList.remove("text-slate-300");
            }
        });
        };
    </script>
